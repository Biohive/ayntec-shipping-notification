# ─── Application ────────────────────────────────────────────────────────────
APP_NAME=Ayntec Shipping Notifier
APP_URL=https://your-domain.example.com
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-hex-string

# Set DEBUG=true only in development
DEBUG=false

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (default – fine for small deployments)
DATABASE_URL=sqlite:///./data/app.db
# PostgreSQL example:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost/ayntec_notifier

# ─── OIDC / Authentik ────────────────────────────────────────────────────────
OIDC_CLIENT_ID=your-authentik-client-id
OIDC_CLIENT_SECRET=your-authentik-client-secret
# Authentik discovery URL format:
# https://<authentik-host>/application/o/<application-slug>/.well-known/openid-configuration
OIDC_DISCOVERY_URL=https://auth.example.com/application/o/ayntec-notifier/.well-known/openid-configuration

# ─── Polling ─────────────────────────────────────────────────────────────────
# How often (in seconds) to check each order. Default: 300 (5 minutes)
POLL_INTERVAL_SECONDS=300

# ─── Ayntec ──────────────────────────────────────────────────────────────────
# URL template for order status pages; {order_id} is replaced at runtime
AYNTEC_ORDER_URL=https://www.ayntec.com/orders/{order_id}

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
# Leave blank to disable email notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=notifications@example.com

# ─── GitHub Repository URL ───────────────────────────────────────────────────
GITHUB_REPO_URL=https://github.com/Biohive/ayntec-shipping-notification
